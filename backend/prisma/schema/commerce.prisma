// ─── Commerce: Transaction, Item, Payment & Breakdown ───────────────────────

model Transaction {
    id                 String            @id @default(uuid())
    reference          String            @unique // Internal reference
    status             TransactionStatus @default(PENDING)
    totalAmountInCents Int
    currency           String            @default("COP")

    // Relations
    items     TransactionItem[]
    payment   Payment?
    breakdown FinancialBreakdown[]

    customer   Customer @relation(fields: [customerId], references: [id])
    customerId String

    sessionId String? // Idempotency key from frontend

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    delivery Delivery?

    @@index([sessionId])
    @@map("transactions")
}

model TransactionItem {
    id            String      @id @default(uuid())
    transactionId String
    transaction   Transaction @relation(fields: [transactionId], references: [id])

    productId String
    product   Product @relation(fields: [productId], references: [id])

    quantity         Int
    unitPriceInCents Int

    @@map("transaction_items")
}

model Payment {
    id            String      @id @default(uuid())
    transactionId String      @unique
    transaction   Transaction @relation(fields: [transactionId], references: [id])

    gatewayId       String? @unique // External provider transaction ID
    cardBrand       String? // VISA | MASTERCARD
    cardLastFour    String?
    gatewayResponse Json? // Raw provider response for audit

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("payments")
}

model FinancialBreakdown {
    id            String      @id @default(uuid())
    transactionId String
    transaction   Transaction @relation(fields: [transactionId], references: [id])

    concept       String // e.g., "SUBTOTAL", "SHIPPING", "PLATFORM_COMMISSION", "VAT"
    amountInCents Int

    @@map("transaction_financial_breakdown")
}
